#!/usr/bin/env bun

const fs = require('fs');
const path = require('path');
const os = require('os');
const readline = require('readline');

const Q_DIR = path.join(os.homedir(), '.q');
const CONFIG_PATH = path.join(Q_DIR, 'config.json');
const HISTORY_PATH = path.join(Q_DIR, 'history.json');

// Initialize paths and load config
if (!fs.existsSync(Q_DIR)) fs.mkdirSync(Q_DIR, { recursive: true });
let CONFIG = { debug: false, system_prompt: "You are a helpful assistant.", model: 'gpt-oss-120b' };
if (fs.existsSync(CONFIG_PATH)) {
  try { CONFIG = { ...CONFIG, ...JSON.parse(fs.readFileSync(CONFIG_PATH, 'utf8')) }; } catch (e) {}
}

const saveConfig = () => fs.writeFileSync(CONFIG_PATH, JSON.stringify(CONFIG, null, 2));
const BASE_URL = process.env.OPENAI_COMPATIBLE_BASE_URL;
const ENDPOINT = BASE_URL
  ? (BASE_URL.includes('/chat/completions')
      ? BASE_URL
      : `${BASE_URL.replace(/\/+$/, '')}/chat/completions`)
  : undefined;
const KEY = process.env.OPENAI_COMPATIBLE_API_KEY;
const MODEL_ENV = process.env.OPENAI_COMPATIBLE_MODEL;
const printOut = (message) => process.stdout.write(`\n${message}\n\n`);
const printErr = (message) => process.stderr.write(`\n${message}\n\n`);
const ENV_DEBUG = !!process.env.DEBUG;
const PACKAGE_PATH = path.join(__dirname, '..', 'package.json');

function getVersion() {
  try {
    return JSON.parse(fs.readFileSync(PACKAGE_PATH, 'utf8')).version || 'unknown';
  } catch (error) {
    return 'unknown';
  }
}

function extractTextContent(content) {
  if (typeof content === 'string') return content;
  if (!Array.isArray(content)) return null;

  const textParts = content
    .map(part => {
      if (typeof part === 'string') return part;
      if (!part || typeof part !== 'object') return null;
      if (typeof part.text === 'string') return part.text;
      if (part.type === 'text' && typeof part.text?.value === 'string') return part.text.value;
      return null;
    })
    .filter(Boolean);

  return textParts.length ? textParts.join('\n') : null;
}

function extractOutputText(data) {
  if (typeof data?.output_text === 'string' && data.output_text) return data.output_text;

  const choiceMessage = data?.choices?.[0]?.message;
  const choiceContent = extractTextContent(choiceMessage?.content);
  if (choiceContent) return choiceContent;

  if (typeof data?.choices?.[0]?.text === 'string' && data.choices[0].text) {
    return data.choices[0].text;
  }

  if (Array.isArray(data?.output)) {
    const textParts = data.output
      .flatMap(item => Array.isArray(item?.content) ? item.content : [])
      .map(part => {
        if (typeof part?.text === 'string') return part.text;
        if (part?.type === 'output_text' && typeof part?.text === 'string') return part.text;
        return null;
      })
      .filter(Boolean);

    if (textParts.length) return textParts.join('\n');
  }

  return null;
}

function extractErrorMessage(data) {
  if (!data || typeof data !== 'object') return null;
  if (typeof data.error === 'string') return data.error;
  if (typeof data.error?.message === 'string') return data.error.message;
  if (typeof data.detail === 'string') return data.detail;
  if (Array.isArray(data.detail)) return data.detail.map(item => item?.msg || JSON.stringify(item)).join('; ');
  if (typeof data.message === 'string') return data.message;
  return null;
}

async function askAI(prompt, debug) {
  if (!ENDPOINT || !KEY) {
    printErr('Error: OPENAI_COMPATIBLE_BASE_URL or OPENAI_COMPATIBLE_API_KEY not set.');
    process.exit(1);
  }

  const hist = fs.existsSync(HISTORY_PATH) ? JSON.parse(fs.readFileSync(HISTORY_PATH, 'utf8')) : [];
  const requestBody = {
    model: MODEL_ENV || CONFIG.model,
    messages: [
      { role: 'system', content: CONFIG.system_prompt },
      { role: 'system', content: 'Be brief in your response.' },
      ...hist,
      { role: 'user', content: prompt }
    ]
  };

  if (ENV_DEBUG) {
    console.error('Request:', JSON.stringify({
      url: ENDPOINT,
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer [redacted]' },
      body: {
        model: requestBody.model,
        messages: [
          { role: 'system', content: CONFIG.system_prompt },
          { role: 'user', content: prompt }
        ]
      }
    }, null, 2));
  }

  const response = await fetch(ENDPOINT, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${KEY}` },
    body: JSON.stringify(requestBody)
  });

  const rawBody = await response.text();
  if (ENV_DEBUG) {
    console.error('Response:', JSON.stringify({
      status: response.status,
      statusText: response.statusText,
      ok: response.ok,
      headers: Object.fromEntries(response.headers.entries()),
      body: rawBody
    }, null, 2));
  }

  let data;
  try {
    data = rawBody ? JSON.parse(rawBody) : {};
  } catch (error) {
    console.error(`Error: ${response.status} ${response.statusText}`);
    if (rawBody) console.error(rawBody);
    return;
  }

  const errorMessage = extractErrorMessage(data);
  if (!response.ok || errorMessage) {
    printErr(`Error: ${errorMessage || `${response.status} ${response.statusText}`}`);
    if (debug) printErr(JSON.stringify(data, null, 2));
    return;
  }

  const content = extractOutputText(data);
  if (!content) {
    printErr('Error: Unrecognized API response shape.');
    if (debug) printErr(JSON.stringify(data, null, 2));
    return;
  }

  const output = debug ? JSON.stringify(data, null, 2) : content;
  
  printOut(output);

  if (!debug) {
    hist.push({ role: 'user', content: prompt }, { role: 'assistant', content });
    fs.writeFileSync(HISTORY_PATH, JSON.stringify(hist, null, 2));
  }
}

(async () => {
  const args = process.argv.slice(2);
  let debug = CONFIG.debug;

  if (args[0] === 'clear') {
    if (fs.existsSync(HISTORY_PATH)) fs.unlinkSync(HISTORY_PATH);
    return printOut('History cleared.');
  }

  if (args[0] === '-v' || args[0] === '--version') {
    return printOut(getVersion());
  }

  if (args[0] === 'debug') {
    debug = !debug;
    printOut(`Debug ${debug ? 'on' : 'off'}`);
    CONFIG.debug = debug;
    saveConfig();
    args.shift();
  }

  if (!args.length) {
    return printErr(
` /\\_/\\
(=^.^=)
(")_(")

======== Banner ========
q - quick LLM prompt

Usage:
  q [debug|clear] <prompt>
  q -v|--version

Params:
  debug   Toggle debug mode (prints full JSON response)
  clear   Clear stored chat history
  -v      Show version

Notes:
  - Reads OPENAI_COMPATIBLE_BASE_URL and OPENAI_COMPATIBLE_API_KEY
  - Uses OPENAI_COMPATIBLE_MODEL if set, otherwise prompts once`
    );
  }

  if (!CONFIG.model_set && !MODEL_ENV) {
    const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
    const answer = await new Promise(r => rl.question(`Enter model [${CONFIG.model}]: `, a => r(a.trim())));
    rl.close();
    if (answer) CONFIG.model = answer;
    CONFIG.model_set = true;
    saveConfig();
  }

  await askAI(args.join(' '), debug);
})();
